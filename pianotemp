        playNote(note);
        await new Promise(resolve => setTimeout(resolve, duration * 0.8));
        setActiveKeys(prev => {
          const next = new Set(prev);
          next.delete(noteObj.key);
          return next;
        });
        releaseNote(note);
        await new Promise(resolve => setTimeout(resolve, duration * 0.2));
      }
    }
    
    setIsPlaying(false);
  };

  const whiteKeys = NOTES.filter(n => n.type === 'white');
  const blackKeys = NOTES.filter(n => n.type === 'black');

  return (
    <div style={{
