              const leftPos = whiteIndex * 46 - 14;
              
              return (
                <div
                  key={noteObj.note}
                  onMouseDown={() => {
                    setActiveKeys(prev => new Set([...prev, noteObj.key]));
                    playNote(noteObj.note);
