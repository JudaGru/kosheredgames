          style={{
            padding: '8px 12px',
            border: '1px solid rgba(255,255,255,0.08)',
            borderRadius: '10px',
            cursor: 'pointer',
            fontSize: '0.75rem',
            fontFamily: 'inherit',
            background: showLabels 
              ? 'rgba(77, 150, 255, 0.2)'
