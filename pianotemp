          style={{
            position: 'absolute',
            left: `calc(50% - ${whiteKeys.length * 23}px + ${p.x}px)`,
            top: `calc(50% + 20px + ${p.y}px)`,
            width: p.size,
            height: p.size,
            borderRadius: '50%',
            background: p.color,
            opacity: p.life,
            boxShadow: `0 0 ${p.size * 2}px ${p.color}`,
            pointerEvents: 'none',
            transform: 'translate(-50%, -50%)',
