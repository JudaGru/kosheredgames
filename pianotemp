export default function PianoGame() {
  const [activeKeys, setActiveKeys] = useState(new Set());
  const [instrument, setInstrument] = useState('piano');
  const [volume, setVolume] = useState(75);
  const [octaveShift, setOctaveShift] = useState(0);
  const [sustain, setSustain] = useState(false);
  const [isRecording, setIsRecording] = useState(false);
  const [recording, setRecording] = useState([]);
  const [isPlaying, setIsPlaying] = useState(false);
  const [showLabels, setShowLabels] = useState(true);
  const [particles, setParticles] = useState([]);
  const [stats, setStats] = useState({ notesPlayed: 0, streak: 0, maxStreak: 0 });
  const [audioStarted, setAudioStarted] = useState(false);
  const [reverb, setReverb] = useState(30);
  
  const synthRef = useRef(null);
  const hammerSynthRef = useRef(null);
  const harmonicsSynthRef = useRef(null);
  const reverbRef = useRef(null);
  const recordingStartRef = useRef(null);
  const sustainedNotesRef = useRef(new Set());
  const particleIdRef = useRef(0);

  useEffect(() => {
    return () => {
      if (synthRef.current) synthRef.current.dispose();
      if (hammerSynthRef.current) hammerSynthRef.current.dispose();
      if (harmonicsSynthRef.current) harmonicsSynthRef.current.dispose();
      if (reverbRef.current) reverbRef.current.dispose();
    };
  }, []);

  const createSynth = useCallback(() => {
    if (synthRef.current) synthRef.current.dispose();
    if (hammerSynthRef.current) hammerSynthRef.current.dispose();
    if (harmonicsSynthRef.current) harmonicsSynthRef.current.dispose();
    if (reverbRef.current) reverbRef.current.dispose();

    // Create reverb for realistic room sound
    reverbRef.current = new Tone.Reverb({
      decay: 2.5,
      wet: reverb / 100,
    }).toDestination();

    const vol = new Tone.Volume(Tone.gainToDb(volume / 100)).connect(reverbRef.current);
    
    switch (instrument) {
      case 'piano':
        // REALISTIC GRAND PIANO
        // Main body - rich fundamental tone with natural decay
        synthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'fatsine',
            count: 3,
            spread: 20,
          },
          envelope: {
            attack: 0.003,
            decay: 1.8,
            sustain: 0.15,
            release: 2.2,
          },
          volume: -3,
        }).connect(vol);
        
        // Hammer attack - percussive initial transient
        hammerSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'triangle',
          },
          envelope: {
            attack: 0.001,
            decay: 0.06,
            sustain: 0,
            release: 0.08,
          },
          volume: -8,
        }).connect(vol);
        
        // Harmonics layer - adds richness and overtones
        harmonicsSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'custom',
            partials: [1, 0.7, 0.4, 0.25, 0.15, 0.08, 0.04],
          },
          envelope: {
            attack: 0.005,
            decay: 2.5,
            sustain: 0.1,
            release: 3,
          },
          volume: -6,
        }).connect(vol);
        break;

      case 'rhodes':
        // RHODES ELECTRIC PIANO - warm, bell-like, smooth jazz tone
        synthRef.current = new Tone.PolySynth(Tone.FMSynth, {
          harmonicity: 3.01,
          modulationIndex: 1.5,
          oscillator: { type: 'sine' },
          envelope: {
            attack: 0.001,
            decay: 1.5,
            sustain: 0.2,
            release: 1.8,
          },
          modulation: { type: 'sine' },
          modulationEnvelope: {
            attack: 0.002,
            decay: 0.8,
            sustain: 0.1,
            release: 1.2,
          },
          volume: -2,
        }).connect(vol);
        
        // Bell-like overtone for that classic Rhodes shimmer
        hammerSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: { type: 'sine' },
          envelope: {
            attack: 0.001,
            decay: 0.4,
            sustain: 0,
            release: 0.5,
          },
          volume: -12,
        }).connect(vol);
        
        harmonicsSynthRef.current = null;
        break;

      case 'clavinet':
        // CLAVINET - funky, percussive, wah-like
        synthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'sawtooth',
          },
          envelope: {
            attack: 0.001,
            decay: 0.3,
            sustain: 0.15,
            release: 0.2,
          },
          volume: -4,
        }).connect(vol);
        
        // Add the characteristic pluck/bark
        hammerSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: { type: 'square' },
          envelope: {
            attack: 0.001,
            decay: 0.08,
            sustain: 0,
            release: 0.05,
          },
          volume: -10,
        }).connect(vol);
        
        harmonicsSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: { type: 'pulse', width: 0.3 },
          envelope: {
            attack: 0.001,
            decay: 0.25,
            sustain: 0.1,
            release: 0.15,
          },
          volume: -8,
        }).connect(vol);
        break;

      case 'musicbox':
        // MUSIC BOX - delicate, crystalline, nostalgic
        synthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'sine',
          },
          envelope: {
            attack: 0.001,
            decay: 2.5,
            sustain: 0,
            release: 2,
          },
          volume: -3,
        }).connect(vol);
        
        // Metallic tine sound - using FM for bell-like quality
        hammerSynthRef.current = new Tone.PolySynth(Tone.FMSynth, {
          harmonicity: 8,
          modulationIndex: 2,
          oscillator: { type: 'sine' },
          envelope: {
            attack: 0.001,
            decay: 0.8,
            sustain: 0,
            release: 0.5,
          },
          modulation: { type: 'sine' },
          modulationEnvelope: {
            attack: 0.001,
            decay: 0.3,
            sustain: 0,
            release: 0.3,
          },
          volume: -15,
        }).connect(vol);
        
        // Shimmer overtone
        harmonicsSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'sine',
            partials: [1, 0.5, 0.25],
          },
          envelope: {
            attack: 0.001,
            decay: 1.5,
            sustain: 0,
            release: 1.5,
          },
          volume: -10,
        }).connect(vol);
        break;

      case 'strings':
        // ORCHESTRAL STRINGS - lush, warm, cinematic
        synthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'fatsawtooth',
            count: 4,
            spread: 30,
          },
          envelope: {
            attack: 0.3,
            decay: 0.5,
            sustain: 0.8,
            release: 1.5,
          },
          volume: -4,
        }).connect(vol);
        
        // Second layer for richness
        hammerSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'fatsawtooth',
            count: 3,
            spread: 25,
          },
          envelope: {
            attack: 0.35,
            decay: 0.4,
            sustain: 0.7,
            release: 1.8,
          },
          volume: -8,
        }).connect(vol);
        
        // High shimmer
        harmonicsSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'sine',
          },
          envelope: {
            attack: 0.4,
            decay: 0.3,
            sustain: 0.5,
            release: 2,
          },
          volume: -12,
        }).connect(vol);
        break;

      case 'bass':
        // SYNTH BASS - fat, punchy Moog-style
        synthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'fatsawtooth',
            count: 2,
            spread: 10,
          },
          envelope: {
            attack: 0.01,
            decay: 0.3,
            sustain: 0.4,
            release: 0.4,
          },
          volume: 0,
        }).connect(vol);
        
        // Sub bass layer
        hammerSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: { type: 'sine' },
          envelope: {
            attack: 0.01,
            decay: 0.4,
            sustain: 0.5,
            release: 0.5,
          },
          volume: -3,
        }).connect(vol);
        
        // Gritty overtone
        harmonicsSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: { type: 'square' },
          envelope: {
            attack: 0.01,
            decay: 0.2,
            sustain: 0.2,
            release: 0.3,
          },
          volume: -12,
        }).connect(vol);
        break;

      case 'organ':
        // HAMMOND ORGAN - classic B3 sound
        synthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: {
            type: 'custom',
            partials: [1, 1, 0.5, 0.5, 0.25, 0.25, 0.125, 0.125, 0.0625],
          },
          envelope: { attack: 0.02, decay: 0.1, sustain: 0.9, release: 0.1 },
          volume: -3,
        }).connect(vol);
        
        // Percussion click
        hammerSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: { type: 'sine' },
          envelope: {
            attack: 0.001,
            decay: 0.15,
            sustain: 0,
            release: 0.1,
          },
          volume: -8,
        }).connect(vol);
        
        harmonicsSynthRef.current = null;
        break;
        
      case 'synth':
        // SYNTH LEAD - bright, cutting
        synthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: { 
            type: 'fatsawtooth',
            count: 3,
            spread: 20,
          },
          envelope: { attack: 0.01, decay: 0.3, sustain: 0.5, release: 0.8 },
          volume: -4,
        }).connect(vol);
        
        // PWM layer
        hammerSynthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: { type: 'pulse', width: 0.4 },
          envelope: { attack: 0.01, decay: 0.25, sustain: 0.4, release: 0.7 },
          volume: -8,
        }).connect(vol);
        
        harmonicsSynthRef.current = null;
        break;
        
      default:
        synthRef.current = new Tone.PolySynth(Tone.Synth, {
          oscillator: { type: 'triangle' },
          envelope: { attack: 0.005, decay: 0.3, sustain: 0.4, release: 1.2 }
        }).connect(vol);
        hammerSynthRef.current = null;
        harmonicsSynthRef.current = null;
    }
  }, [instrument, volume, reverb]);

  useEffect(() => {
    if (audioStarted) {
      createSynth();
    }
  }, [instrument, volume, reverb, createSynth, audioStarted]);

  const shiftNote = (note) => {
    if (octaveShift === 0) return note;
    const match = note.match(/([A-G]#?)(\d)/);
    if (match) {
      const [, pitch, octave] = match;
      return `${pitch}${parseInt(octave) + octaveShift}`;
    }
    return note;
  };

  const createParticle = (note) => {
    const noteIndex = NOTES.findIndex(n => n.note === note);
    const isBlack = NOTES[noteIndex]?.type === 'black';
    const whiteKeysBefore = NOTES.filter((n, i) => i <= noteIndex && n.type === 'white').length - 1;
    
    const colors = ['#ff6b6b', '#ffd93d', '#6bcb77', '#4d96ff', '#9b59b6', '#ff85a1', '#00d4ff', '#ff9f43'];
    
    for (let i = 0; i < 8; i++) {
      const id = particleIdRef.current++;
      const particle = {
        id,
        x: isBlack ? (whiteKeysBefore * 46 + 28) : (whiteKeysBefore * 46 + 23),
        y: isBlack ? 70 : 180,
        vx: (Math.random() - 0.5) * 10,
        vy: -Math.random() * 12 - 6,
        color: colors[Math.floor(Math.random() * colors.length)],
        size: Math.random() * 10 + 5,
        life: 1,
      };
      setParticles(prev => [...prev, particle]);
    }
  };

  useEffect(() => {
    const interval = setInterval(() => {
      setParticles(prev => {
        return prev
          .map(p => ({
            ...p,
            x: p.x + p.vx,
            y: p.y + p.vy,
            vy: p.vy + 0.6,
            life: p.life - 0.025,
          }))
          .filter(p => p.life > 0);
      });
    }, 30);
    return () => clearInterval(interval);
  }, []);

  const playNote = useCallback(async (note) => {
    if (!audioStarted) {
      await Tone.start();
      setAudioStarted(true);
      createSynth();
    }
    
    if (!synthRef.current) {
      createSynth();
    }
    
    const shiftedNote = shiftNote(note);
    
    // Add velocity variation for more realistic sound
    const velocity = 0.6 + Math.random() * 0.4;
    const now = Tone.now();
    
    synthRef.current?.triggerAttack(shiftedNote, now, velocity);
    hammerSynthRef.current?.triggerAttack(shiftedNote, now, velocity * 1.2);
    harmonicsSynthRef.current?.triggerAttack(shiftedNote, now, velocity * 0.7);
    
    if (sustain) {
      sustainedNotesRef.current.add(shiftedNote);
    }
    
    createParticle(note);
    
    setStats(prev => ({
      notesPlayed: prev.notesPlayed + 1,
      streak: prev.streak + 1,
      maxStreak: Math.max(prev.maxStreak, prev.streak + 1)
    }));
    
    if (isRecording) {
      setRecording(prev => [...prev, {
        note,
        time: Date.now() - recordingStartRef.current,
        type: 'attack'
      }]);
    }
  }, [octaveShift, sustain, isRecording, audioStarted, createSynth]);

  const releaseNote = useCallback((note) => {
    const shiftedNote = shiftNote(note);
    const now = Tone.now();
    
    if (!sustain) {
      synthRef.current?.triggerRelease(shiftedNote, now);
      hammerSynthRef.current?.triggerRelease(shiftedNote, now);
      harmonicsSynthRef.current?.triggerRelease(shiftedNote, now);
    }
    
    if (isRecording) {
      setRecording(prev => [...prev, {
        note,
        time: Date.now() - recordingStartRef.current,
        type: 'release'
      }]);
    }
  }, [octaveShift, sustain, isRecording]);

  const handleKeyDown = useCallback((e) => {
    if (e.repeat) return;
    const key = e.key.toLowerCase();
    
    if (key === ' ') {
      e.preventDefault();
      setSustain(true);
      return;
    }
    
    if (key === 'backspace') {
      e.preventDefault();
      setOctaveShift(prev => Math.max(prev - 1, -2));
      return;
    }
    if (key === '\\') {
      setOctaveShift(prev => Math.min(prev + 1, 2));
      return;
    }
    
    const noteObj = NOTES.find(n => n.key === key);
    if (noteObj && !activeKeys.has(key)) {
      setActiveKeys(prev => new Set([...prev, key]));
      playNote(noteObj.note);
    }
  }, [activeKeys, playNote]);

  const handleKeyUp = useCallback((e) => {
    const key = e.key.toLowerCase();
    
    if (key === ' ') {
      setSustain(false);
      const now = Tone.now();
      sustainedNotesRef.current.forEach(note => {
        synthRef.current?.triggerRelease(note, now);
        hammerSynthRef.current?.triggerRelease(note, now);
        harmonicsSynthRef.current?.triggerRelease(note, now);
      });
      sustainedNotesRef.current.clear();
      return;
    }
    
    const noteObj = NOTES.find(n => n.key === key);
    if (noteObj) {
      setActiveKeys(prev => {
        const next = new Set(prev);
        next.delete(key);
        return next;
      });
      releaseNote(noteObj.note);
    }
  }, [releaseNote]);

  useEffect(() => {
    window.addEventListener('keydown', handleKeyDown);
    window.addEventListener('keyup', handleKeyUp);
    return () => {
      window.removeEventListener('keydown', handleKeyDown);
      window.removeEventListener('keyup', handleKeyUp);
    };
  }, [handleKeyDown, handleKeyUp]);

  const startRecording = () => {
    setRecording([]);
    setIsRecording(true);
    recordingStartRef.current = Date.now();
  };

  const stopRecording = () => {
    setIsRecording(false);
  };

  const playRecording = async () => {
    if (recording.length === 0) return;
    setIsPlaying(true);
    
    for (const event of recording) {
      await new Promise(resolve => setTimeout(resolve, event.time - (recording[recording.indexOf(event) - 1]?.time || 0)));
      const noteObj = NOTES.find(n => n.note === event.note);
      if (noteObj) {
        if (event.type === 'attack') {
          setActiveKeys(prev => new Set([...prev, noteObj.key]));
          playNote(event.note);
        } else {
          setActiveKeys(prev => {
            const next = new Set(prev);
            next.delete(noteObj.key);
            return next;
          });
          releaseNote(event.note);
        }
      }
    }
    
    setIsPlaying(false);
    setActiveKeys(new Set());
  };

  const playDemo = async (songName) => {
    const song = DEMO_SONGS[songName];
    if (!song) return;
    
    setIsPlaying(true);
    
    for (const { note, duration } of song) {
      const noteObj = NOTES.find(n => n.note === note);
      if (noteObj) {
