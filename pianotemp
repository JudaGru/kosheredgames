            color: showLabels ? '#4d96ff' : 'rgba(255,255,255,0.6)',
            transition: 'all 0.2s',
          }}
        >
          🏷️ Labels
        </button>
      </div>

      {/* Recording Controls */}
      <div style={{
        display: 'flex',
        justifyContent: 'center',
        gap: '10px',
        marginBottom: '15px',
