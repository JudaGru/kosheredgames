        <button
          onClick={isRecording ? stopRecording : startRecording}
          disabled={isPlaying}
          style={{
            padding: '10px 20px',
            border: 'none',
            borderRadius: '20px',
            cursor: isPlaying ? 'not-allowed' : 'pointer',
            fontSize: '0.8rem',
            fontFamily: 'inherit',
            fontWeight: 'bold',
            letterSpacing: '0.1em',
            background: isRecording 
              ? 'linear-gradient(135deg, #ff6b6b, #ee5a5a)'
              : 'linear-gradient(135deg, #333, #444)',
            color: '#fff',
            boxShadow: isRecording 
              ? '0 0 30px rgba(255, 107, 107, 0.5)'
              : 'none',
            transition: 'all 0.3s',
            opacity: isPlaying ? 0.5 : 1,
          }}
        >
          {isRecording ? '⏹️ STOP' : '⏺️ RECORD'}
        </button>
        
        <button
          onClick={playRecording}
          disabled={recording.length === 0 || isPlaying || isRecording}
          style={{
            padding: '10px 20px',
            border: 'none',
            borderRadius: '20px',
            cursor: (recording.length === 0 || isPlaying || isRecording) ? 'not-allowed' : 'pointer',
            fontSize: '0.8rem',
            fontFamily: 'inherit',
            fontWeight: 'bold',
            letterSpacing: '0.1em',
            background: 'linear-gradient(135deg, #6bcb77, #5ab868)',
            color: '#fff',
            opacity: (recording.length === 0 || isPlaying || isRecording) ? 0.3 : 1,
            transition: 'all 0.3s',
          }}
        >
          ▶️ PLAY ({recording.filter(r => r.type === 'attack').length})
        </button>

        {/* Demo Songs */}
        {Object.keys(DEMO_SONGS).map(song => (
          <button
            key={song}
            onClick={() => playDemo(song)}
            disabled={isPlaying || isRecording}
            style={{
              padding: '10px 14px',
              border: '1px solid rgba(255, 217, 61, 0.3)',
              borderRadius: '20px',
              cursor: (isPlaying || isRecording) ? 'not-allowed' : 'pointer',
              fontSize: '0.75rem',
              fontFamily: 'inherit',
              background: 'rgba(255, 217, 61, 0.1)',
              color: '#ffd93d',
              opacity: (isPlaying || isRecording) ? 0.3 : 1,
              transition: 'all 0.3s',
            }}
          >
            🎵 {song}
          </button>
        ))}
      </div>

      {/* Piano */}
      <div style={{
        display: 'flex',
        justifyContent: 'center',
        alignItems: 'flex-start',
        position: 'relative',
        padding: '10px',
        overflowX: 'auto',
      }}>
        <div style={{
          position: 'relative',
          background: 'linear-gradient(180deg, #1a1a2e 0%, #0d0d12 100%)',
          padding: '20px 15px 15px',
          borderRadius: '16px',
          boxShadow: '0 30px 100px rgba(0,0,0,0.9), inset 0 1px 0 rgba(255,255,255,0.08)',
          border: '1px solid rgba(255,255,255,0.05)',
        }}>
          {/* Piano body decoration */}
          <div style={{
            position: 'absolute',
            top: '8px',
            left: '50%',
            transform: 'translateX(-50%)',
            width: '80px',
            height: '3px',
            background: 'linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.5), transparent)',
            borderRadius: '2px',
          }} />

          {/* Octave labels */}
          <div style={{
            display: 'flex',
            position: 'absolute',
            top: '-18px',
            left: '15px',
            right: '15px',
          }}>
            {['C3', 'C4', 'C5', 'C6'].map((octave) => {
              const whiteKeyIndex = whiteKeys.findIndex(k => k.note === octave);
              if (whiteKeyIndex === -1) return null;
              return (
                <div
                  key={octave}
                  style={{
                    position: 'absolute',
                    left: `${whiteKeyIndex * 46 + 10}px`,
                    color: 'rgba(255,255,255,0.3)',
                    fontSize: '0.65rem',
                    letterSpacing: '0.1em',
                  }}
                >
                  {octave}
                </div>
              );
            })}
          </div>

          <div style={{
            display: 'flex',
            position: 'relative',
          }}>
            {/* White Keys */}
            {whiteKeys.map((noteObj, index) => {
              const isActive = activeKeys.has(noteObj.key);
              return (
                <div
                  key={noteObj.note}
                  onMouseDown={() => {
                    setActiveKeys(prev => new Set([...prev, noteObj.key]));
                    playNote(noteObj.note);
                  }}
                  onMouseUp={() => {
                    setActiveKeys(prev => {
                      const next = new Set(prev);
                      next.delete(noteObj.key);
                      return next;
                    });
                    releaseNote(noteObj.note);
                  }}
                  onMouseLeave={() => {
                    if (activeKeys.has(noteObj.key)) {
                      setActiveKeys(prev => {
                        const next = new Set(prev);
                        next.delete(noteObj.key);
                        return next;
                      });
                      releaseNote(noteObj.note);
                    }
                  }}
                  style={{
                    width: '44px',
                    height: '200px',
                    background: isActive
                      ? 'linear-gradient(180deg, #e0e0e0 0%, #c8c8c8 100%)'
                      : 'linear-gradient(180deg, #ffffff 0%, #f5f5f5 30%, #e8e8e8 70%, #d8d8d8 100%)',
                    border: '1px solid #aaa',
                    borderRadius: '0 0 6px 6px',
                    marginRight: index < whiteKeys.length - 1 ? '2px' : '0',
