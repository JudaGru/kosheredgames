      ))}

      {/* Header */}
      <div style={{
        textAlign: 'center',
        marginBottom: '12px',
      }}>
        <h1 style={{
          fontSize: '2.5rem',
          fontWeight: '300',
          color: '#fff',
          letterSpacing: '0.3em',
          textTransform: 'uppercase',
          margin: 0,
          textShadow: '0 0 30px rgba(139, 92, 246, 0.5), 0 0 60px rgba(236, 72, 153, 0.3)',
        }}>
          🎹 GRAND PIANO STUDIO
        </h1>
        <p style={{
          color: 'rgba(255,255,255,0.4)',
          fontSize: '0.75rem',
