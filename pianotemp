          padding: '6px 12px',
          borderRadius: '10px',
          border: sustain 
            ? '1px solid rgba(107, 203, 119, 0.5)'
            : '1px solid rgba(255,255,255,0.08)',
          transition: 'all 0.2s',
        }}>
          <span style={{ 
            color: sustain ? '#6bcb77' : 'rgba(255,255,255,0.4)',
            fontSize: '0.75rem',
          }}>
            ⏸️ SUSTAIN {sustain ? 'ON' : 'OFF'}
          </span>
        </div>

        {/* Show Labels Toggle */}
        <button
